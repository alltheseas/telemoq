{
  mode: "router",
  listen: {
    endpoints: [
      "quic/0.0.0.0:7447?multistream=1",
      "tcp/0.0.0.0:7448",
    ],
  },
  scouting: {
    multicast: { enabled: false },
  },
  transport: {
    link: {
      tls: {
        listen_private_key: "config/tls/key.pem",
        listen_certificate: "config/tls/cert.pem",
        verify_name_on_connect: false,
      },
    },
  },
}
