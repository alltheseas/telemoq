{
  mode: "client",
  connect: {
    endpoints: ["quic/127.0.0.1:7447?multistream=1"],
  },
  scouting: {
    multicast: { enabled: false },
  },
  transport: {
    link: {
      tls: {
        root_ca_certificate: "config/tls/cert.pem",
        verify_name_on_connect: false,
      },
    },
  },
}
